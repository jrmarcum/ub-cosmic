# ub-cosmic layout: Compact panel (thin bottom bar, grouped)
# DRAFT — tune on a live VM.
[org/gnome/shell]
enabled-extensions=['dash-to-panel@jderose9.github.com', 'appindicatorsupport@rgcjonas.gmail.com']

[org/gnome/shell/extensions/dash-to-panel]
panel-positions='{"0":"BOTTOM"}'
panel-sizes='{"0":32}'
group-apps=true
appicon-margin=2
show-appmenu=false
