#!/usr/bin/bash
# ub-cosmic-layout — switch the COSMIC desktop between preset layouts.
#
# A "layout" is a snapshot of the cosmic-config directories that define the
# panel/dock/theme/background/compositor. This tool copies those directories in
# and out of ~/.config/cosmic — it never parses RON, so presets are built by
# CAPTURING a hand-tuned live COSMIC session (see LAYOUTS.md).
#
#   System presets: /usr/share/ub-cosmic/cosmic-layouts/<name>/
#   User presets:   ~/.config/ub-cosmic/cosmic-layouts/<name>/   (captures / overrides)
#
# Usage:
#   ub-cosmic-layout list                 # list available layouts
#   ub-cosmic-layout current              # show the active layout (if known)
#   ub-cosmic-layout set <name>           # apply a layout (log out/in to finish)
#   ub-cosmic-layout capture <name>       # save the CURRENT COSMIC desktop as a preset
#   ub-cosmic-layout reset                # remove layout config (COSMIC regenerates defaults)
#
# NOTE: COSMIC applies most config live, but panel/dock structure changes are
# safest after a LOG OUT / LOG IN.
set -uo pipefail

CFG_HOME="${XDG_CONFIG_HOME:-$HOME/.config}"
COSMIC_CFG="${CFG_HOME}/cosmic"
SYS_DIR="/usr/share/ub-cosmic/cosmic-layouts"
USER_DIR="${CFG_HOME}/ub-cosmic/cosmic-layouts"
STATE_FILE="${CFG_HOME}/ub-cosmic/current-layout"

# cosmic-config entries that make up a "layout". Globs are matched under
# $COSMIC_CFG; curated so captures don't drag in unrelated app state
# (CosmicFiles/CosmicTerm/CosmicEdit, etc.). Extend this list if a layout starts
# depending on another component.
INCLUDE_GLOBS=(
    'com.system76.CosmicPanel*'      # panels, dock, entries
    'com.system76.CosmicComp*'       # compositor: workspaces, tiling, keybinds
    'com.system76.CosmicTheme*'      # light/dark/mode, accent
    'com.system76.CosmicBackground*' # wallpaper
    'com.system76.CosmicTk*'         # toolkit prefs
    'applets'                        # applet configs
)

die() { echo "ub-cosmic-layout: $*" >&2; exit 1; }

preset_dir() {
    local name="$1"
    if [[ -d "${USER_DIR}/${name}" ]]; then echo "${USER_DIR}/${name}"; return 0; fi
    if [[ -d "${SYS_DIR}/${name}" ]]; then echo "${SYS_DIR}/${name}"; return 0; fi
    return 1
}

cmd_list() {
    echo "Available layouts:"
    { [[ -d "$SYS_DIR" ]] && find "$SYS_DIR" -mindepth 1 -maxdepth 1 -type d -printf '%f\n'
      [[ -d "$USER_DIR" ]] && find "$USER_DIR" -mindepth 1 -maxdepth 1 -type d -printf '%f\n'; } \
        2>/dev/null | sort -u | sed 's/^/  /'
    [[ -f "$STATE_FILE" ]] && echo "Current: $(cat "$STATE_FILE")"
}

cmd_current() { [[ -f "$STATE_FILE" ]] && cat "$STATE_FILE" || echo "unknown"; }

cmd_set() {
    local name="${1:-}"; [[ -n "$name" ]] || die "usage: ub-cosmic-layout set <name>"
    local src; src="$(preset_dir "$name")" || die "unknown layout '$name' (try: ub-cosmic-layout list)"
    [[ -n "$(ls -A "$src" 2>/dev/null)" ]] || die "layout '$name' has no content yet — capture it on a live session first"
    mkdir -p "$COSMIC_CFG"
    # Replace each component the preset carries; leave unrelated COSMIC config alone.
    local entry base
    for entry in "$src"/*; do
        [[ -e "$entry" ]] || continue
        base="$(basename "$entry")"
        rm -rf "${COSMIC_CFG:?}/${base}"
        cp -a "$entry" "$COSMIC_CFG/"
    done
    mkdir -p "$(dirname "$STATE_FILE")"; echo "$name" > "$STATE_FILE"
    echo "Applied layout '$name'. Log out and back in to fully apply."
}

cmd_capture() {
    local name="${1:-}"; [[ -n "$name" ]] || die "usage: ub-cosmic-layout capture <name>"
    [[ -d "$COSMIC_CFG" ]] || die "no COSMIC config found at $COSMIC_CFG (are you in a COSMIC session?)"
    local dest="${USER_DIR}/${name}"
    rm -rf "$dest"; mkdir -p "$dest"
    shopt -s nullglob
    local pat entry got=0
    for pat in "${INCLUDE_GLOBS[@]}"; do
        for entry in "$COSMIC_CFG"/$pat; do
            [[ -e "$entry" ]] && { cp -a "$entry" "$dest/"; got=1; }
        done
    done
    shopt -u nullglob
    [[ "$got" -eq 1 ]] || die "captured nothing — no matching cosmic-config components found"
    echo "Captured current COSMIC desktop to ${dest}"
    echo "To ship it as a default, copy it into the repo at:"
    echo "  system_files${SYS_DIR}/${name}/"
    echo "(and set DEFAULT_LAYOUT in build.sh if this should be the baked default)."
}

cmd_reset() {
    shopt -s nullglob
    local pat entry
    for pat in "${INCLUDE_GLOBS[@]}"; do
        for entry in "$COSMIC_CFG"/$pat; do rm -rf "$entry"; done
    done
    shopt -u nullglob
    rm -f "$STATE_FILE"
    echo "Removed layout config. Log out/in — COSMIC will regenerate its defaults."
}

case "${1:-}" in
    list)    cmd_list ;;
    current) cmd_current ;;
    set)     cmd_set "${2:-}" ;;
    capture) cmd_capture "${2:-}" ;;
    reset)   cmd_reset ;;
    *) echo "usage: ub-cosmic-layout {list|current|set <name>|capture <name>|reset}" >&2; exit 2 ;;
esac
