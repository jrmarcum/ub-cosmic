#!/usr/bin/bash
# ub-cosmic-layout — switch the GNOME session between Zorin-style desktop layouts.
#
# Layouts are dconf keyfiles in /usr/share/ub-cosmic/layouts/<name>.dconf (system)
# and ~/.config/ub-cosmic/layouts/<name>.dconf (user overrides / captures).
# Applying a layout resets the relevant dconf subtrees, then loads the preset.
#
# Usage:
#   ub-cosmic-layout list                 # list available layouts
#   ub-cosmic-layout current              # show the active layout (if known)
#   ub-cosmic-layout set <name>           # apply a layout (log out/in to finish)
#   ub-cosmic-layout reset                # clear layout-related dconf to GNOME stock
#   ub-cosmic-layout capture <name>       # save the CURRENT desktop as a preset
#
# NOTE: On Wayland, GNOME Shell can't hot-reload extensions — after `set`, log out
# and back in (or reboot) for the layout to fully apply.
set -uo pipefail

SYS_DIR="/usr/share/ub-cosmic/layouts"
USER_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/ub-cosmic/layouts"
STATE_FILE="${XDG_CONFIG_HOME:-$HOME/.config}/ub-cosmic/current-layout"

# dconf subtrees a layout owns. `set`/`reset` clear these before applying so
# switching layouts doesn't leave stale keys from the previous one.
OWNED_PATHS=(
    /org/gnome/shell/extensions/dash-to-panel/
    /org/gnome/shell/extensions/dash-to-dock/
    /org/gnome/shell/extensions/arcmenu/
)
# Individual keys (not whole subtrees) a layout sets.
OWNED_KEYS=(
    /org/gnome/shell/enabled-extensions
    /org/gnome/shell/favorite-apps
    /org/gnome/desktop/interface/color-scheme
    /org/gnome/desktop/interface/gtk-theme
    /org/gnome/desktop/wm/preferences/button-layout
)

die() { echo "ub-cosmic-layout: $*" >&2; exit 1; }

preset_path() {
    # User override wins over the system preset.
    local name="$1"
    if [[ -f "${USER_DIR}/${name}.dconf" ]]; then echo "${USER_DIR}/${name}.dconf"; return 0; fi
    if [[ -f "${SYS_DIR}/${name}.dconf" ]]; then echo "${SYS_DIR}/${name}.dconf"; return 0; fi
    return 1
}

cmd_list() {
    echo "Available layouts:"
    { [[ -d "$SYS_DIR" ]] && ls "$SYS_DIR"/*.dconf 2>/dev/null
      [[ -d "$USER_DIR" ]] && ls "$USER_DIR"/*.dconf 2>/dev/null; } \
        | xargs -r -n1 basename 2>/dev/null | sed 's/\.dconf$//' | sort -u \
        | sed 's/^/  /'
    [[ -f "$STATE_FILE" ]] && echo "Current: $(cat "$STATE_FILE")"
}

cmd_current() { [[ -f "$STATE_FILE" ]] && cat "$STATE_FILE" || echo "unknown"; }

cmd_reset() {
    for p in "${OWNED_PATHS[@]}"; do dconf reset -f "$p"; done
    for k in "${OWNED_KEYS[@]}"; do dconf reset "$k"; done
    echo "Reset layout-related settings to GNOME defaults. Log out/in to apply."
}

cmd_set() {
    local name="${1:-}"; [[ -n "$name" ]] || die "usage: ub-cosmic-layout set <name>"
    local file; file="$(preset_path "$name")" || die "unknown layout '$name' (try: ub-cosmic-layout list)"
    # Clear the previous layout's keys, then load the new preset.
    for p in "${OWNED_PATHS[@]}"; do dconf reset -f "$p"; done
    for k in "${OWNED_KEYS[@]}"; do dconf reset "$k"; done
    dconf load / < "$file" || die "failed to load preset $file"
    mkdir -p "$(dirname "$STATE_FILE")"; echo "$name" > "$STATE_FILE"
    echo "Applied layout '$name'. Log out and back in (or reboot) to finish."
}

cmd_capture() {
    local name="${1:-}"; [[ -n "$name" ]] || die "usage: ub-cosmic-layout capture <name>"
    mkdir -p "$USER_DIR"
    local out="${USER_DIR}/${name}.dconf"
    {
        echo "# ub-cosmic layout '${name}' captured from a live session."
        # Dump each owned subtree, re-prefixing section headers to absolute paths
        # so the file can be applied with `dconf load /`.
        for p in "${OWNED_PATHS[@]}"; do
            local base="${p#/}"; base="${base%/}"           # e.g. org/gnome/shell/extensions/dash-to-panel
            dconf dump "$p" 2>/dev/null | awk -v b="$base" '
                /^\[/ {
                    s = substr($0, 2, length($0)-2)         # strip [ ]
                    if (s == "/") printf("[%s]\n", b); else printf("[%s/%s]\n", b, s); next
                }
                { print }'
        done
        # Individual keys → group them under their parent sections.
        echo "[org/gnome/shell]"
        for key in enabled-extensions favorite-apps; do
            v="$(dconf read "/org/gnome/shell/${key}")"; [[ -n "$v" ]] && echo "${key}=${v}"
        done
        echo "[org/gnome/desktop/interface]"
        for key in color-scheme gtk-theme; do
            v="$(dconf read "/org/gnome/desktop/interface/${key}")"; [[ -n "$v" ]] && echo "${key}=${v}"
        done
        v="$(dconf read /org/gnome/desktop/wm/preferences/button-layout)"
        [[ -n "$v" ]] && { echo "[org/gnome/desktop/wm/preferences]"; echo "button-layout=${v}"; }
    } > "$out"
    echo "Captured current desktop to ${out}"
    echo "Copy it into the repo at system_files${SYS_DIR}/${name}.dconf to ship it as a default."
}

case "${1:-}" in
    list)    cmd_list ;;
    current) cmd_current ;;
    set)     cmd_set "${2:-}" ;;
    reset)   cmd_reset ;;
    capture) cmd_capture "${2:-}" ;;
    *) echo "usage: ub-cosmic-layout {list|current|set <name>|reset|capture <name>}" >&2; exit 2 ;;
esac
