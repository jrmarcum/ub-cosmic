# Parameters for the image build. Sourced by the Justfile.

# Output image name — matches the repo/GHCR package name.
IMAGE_NAME=ub-cosmic

# Your GitHub username or organization. CHANGE THIS.
# (The GitHub Actions workflows derive the registry from the repo owner
#  automatically, so this only affects local `just` builds and ArtifactHub labels.)
REPO_ORGANIZATION="CHANGE_ME"

IMAGE_DESC="Universal Blue COSMIC Desktop Edition (Bazzite base, GNOME backup)"
IMAGE_KEYWORDS="bootc,oci,linux,bazzite,cosmic,universal-blue"

IMAGE_LOGO_URL="https://avatars.githubusercontent.com/u/120078124?s=200&v=4"
DEFAULT_TAG="latest"
BIB_IMAGE="quay.io/centos-bootc/bootc-image-builder:latest"
